rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function ownsUserDocument(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function ownsDataDocument() {
      return isSignedIn() && request.resource.data.userId == request.auth.uid;
    }

    function ownsExistingDataDocument() {
      return isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /users/{userId} {
      allow read, create, update, delete: if ownsUserDocument(userId);
    }

    match /routine_items/{documentId} {
      allow read, delete: if ownsExistingDataDocument();
      allow create: if ownsDataDocument();
      allow update: if ownsExistingDataDocument() && ownsDataDocument();
    }

    match /activities/{documentId} {
      allow read, delete: if ownsExistingDataDocument();
      allow create: if ownsDataDocument();
      allow update: if ownsExistingDataDocument() && ownsDataDocument();
    }

    match /study_topics/{documentId} {
      allow read, delete: if ownsExistingDataDocument();
      allow create: if ownsDataDocument();
      allow update: if ownsExistingDataDocument() && ownsDataDocument();
    }

    match /pomodoro_sessions/{documentId} {
      allow read, delete: if ownsExistingDataDocument();
      allow create: if ownsDataDocument();
      allow update: if ownsExistingDataDocument() && ownsDataDocument();
    }
  }
}
